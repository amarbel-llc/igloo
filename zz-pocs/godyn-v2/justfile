set shell := ["bash", "-euo", "pipefail", "-c"]

v2 := justfile_directory()
poc := v2 / "../godyn-poc"

# Regenerate graph.json from the module. Run after the import structure / file
# set changes — NOT after a content-only edit (same contract as gomod2nix.toml).
[group('dev')]
gen:
    #!/usr/bin/env bash
    set -euo pipefail
    goStore=$(nix build --no-link --print-out-paths '{{poc}}#go-toolchain^out')
    export PATH="$goStore/bin:$PATH" GOCACHE=$(mktemp -d)
    cd {{v2}}/gen && go build -o /tmp/godyn-gen .
    /tmp/godyn-gen {{v2}}/module {{v2}}/graph.json

# Build all three approaches and run each (they must print the same value).
[group('build')]
build:
    #!/usr/bin/env bash
    set -euo pipefail
    cd {{v2}}
    for t in native recursive bga; do
      o=$(nix build ".#$t" --no-link --print-out-paths 2>/dev/null)
      printf '%-10s %s\n' "$t:" "$($o/bin/godyntb)"
    done

# JSON benchmark: edit-loop wall-clock + rebuild counts across the three
# approaches, `runs` samples each (unique edit token per run). module=toy|tommy.
# Emits structured JSON to stdout (see bench.sh).
[group('explore')]
bench module="toy" runs="3":
    #!/usr/bin/env bash
    set -euo pipefail
    jqbin=$(nix build --no-link --print-out-paths nixpkgs#jq 2>/dev/null)/bin
    export PATH="$jqbin:$PATH"
    bash {{v2}}/bench.sh {{module}} {{runs}}

# Same benchmark rendered as a markdown table (median ms · rebuilt pkgs).
[group('explore')]
bench-md module="toy" runs="3":
    #!/usr/bin/env bash
    set -euo pipefail
    jqbin=$(nix build --no-link --print-out-paths nixpkgs#jq 2>/dev/null)/bin
    export PATH="$jqbin:$PATH"
    bash {{v2}}/bench.sh {{module}} {{runs}} | jq -r '
      (.results | map(.approach) | unique) as $a |
      "## \(.module) — \(.packages) pkgs, \(.runs) runs (median ms · rebuilt pkgs)",
      "",
      "| scenario | " + ($a | join(" | ")) + " |",
      "|" + ("---|" * (($a | length) + 1)),
      (.results | group_by(.scenario)[]
        | "| \(.[0].scenario) | " + ([.[] | "\(.ms_median)ms·\(.rebuilds)"] | join(" | ")) + " |")
    '
