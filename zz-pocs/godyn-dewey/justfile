set shell := ["bash", "-euo", "pipefail", "-c"]

# godyn-dewey POC. See README.md. The dewey/purse-first source is a gitignored
# clone at $PF (cloned to avoid cross-worktree perms).

pf := "/home/sasha/eng/repos/igloo/.worktrees/sharp-mahogany/.tmp/purse-first"
godyn_poc := "/home/sasha/eng/repos/igloo/.worktrees/sharp-mahogany/zz-pocs/godyn-poc"

# D1: generate the godyn lockfile for dewey's module closure by joining
# purse-first's gomod2nix.toml (path/version + recursive-NAR SRI hash) with
# dewey's go.sum (the h1 ziphash). Excludes bridged tommy. awk uses \047 for
# the single-quote so the program needs no shell-quote escaping.
[group('explore')]
gen-lock:
    #!/usr/bin/env bash
    set -euo pipefail
    awk '
    function val(l,   s,r,e){ s=index(l,"\047"); r=substr(l,s+1); e=index(r,"\047"); return substr(r,1,e-1) }
    NR==FNR { if ($2 !~ /\/go\.mod$/) h1[$1" "$2]=$3; next }
    /\[mod\./ { p=val($0); ver=""; hash="" }
    /^[[:space:]]+version = / { ver=val($0) }
    /^[[:space:]]+hash = / {
      hash=val($0)
      if (p=="github.com/amarbel-llc/tommy") next
      key=p" "ver
      if (key in h1) print p, ver, hash, h1[key]
    }
    ' '{{pf}}/libs/dewey/go.sum' '{{pf}}/gomod2nix.toml' | sort > dewey.lock
    echo "wrote $(wc -l < dewey.lock) modules to dewey.lock"
    echo "--- first 3 ---"; head -3 dewey.lock
    # sanity: every dewey go.sum module (minus tommy) should be covered
    missing=$(comm -23 \
      <(awk '$2 !~ /\/go\.mod$/ {print $1" "$2}' '{{pf}}/libs/dewey/go.sum' | grep -v '^github.com/amarbel-llc/tommy ' | sort -u) \
      <(awk '{print $1" "$2}' dewey.lock | sort -u) | wc -l)
    echo "go.sum modules not covered by the lockfile: $missing (expect 0)"

# D0: dewey inlining density. Materialises dewey's vendor into the clone and
# runs go build -gcflags=-m. CGO off, so the zstd package fails last; the rest
# of the inline data is complete.
[group('explore')]
measure:
    #!/usr/bin/env bash
    set -uo pipefail
    goStore=$(nix build --no-link --print-out-paths '{{godyn_poc}}#go-toolchain^out')
    export PATH="$goStore/bin:$PATH"
    vendorEnv=$(nix build --no-link --print-out-paths '{{pf}}#defererr.passthru.vendorEnv')
    cd '{{pf}}'
    rm -rf vendor; cp -rL "$vendorEnv" vendor; chmod -R +w vendor
    export GOFLAGS=-mod=vendor GOCACHE=$(mktemp -d) CGO_ENABLED=0 \
      GO_NO_VENDOR_CHECKS=1 GOPROXY=off GOSUMDB=off GO111MODULE=on
    go build -gcflags=-m ./libs/dewey/... >/dev/null 2>m-dewey.txt || true
    echo "inlinable:     $(grep -c 'can inline' m-dewey.txt)"
    echo "inlined-calls: $(grep -c 'inlining call to' m-dewey.txt)"
    echo "--- top 22 inline sources ---"
    grep 'inlining call to' m-dewey.txt | sed 's/.*inlining call to //; s/\..*//' \
      | sort | uniq -c | sort -rn | head -22

# Edit-loop head-to-head over dewey's 74-package internal/delta closure:
# native eval-graph (.#dewey-delta-native) vs recursive resolver (.#dewey-delta)
# vs a bga proxy (whole-subtree `go build ./internal/delta/...` from a cold
# GOCACHE — what buildGoApplication redoes in its fresh sandbox every edit).
# Source is the dewey-src path: input; an edit propagates by editing the file +
# `rm -f flake.lock`. Reverts via `git checkout` in the clone. Run the targets
# once first (nix build .#dewey-delta-native .#dewey-delta) so both are warm.
[group('bench')]
bench-delta:
    #!/usr/bin/env bash
    set -uo pipefail
    D='{{pf}}/libs/dewey'
    LEAF="$D/internal/delta/format/main.go"          # in-degree 0 -> cone ~1
    FOUND="$D/internal/0/interfaces/coder.go"         # 22 direct dependents -> large cone
    goStore=$(nix build --no-link --print-out-paths '{{godyn_poc}}#go-toolchain^out')
    revert() { git -C '{{pf}}' checkout -- "$LEAF" "$FOUND" 2>/dev/null; rm -f flake.lock; }
    probe()  { printf '\nfunc gdProbe%s() int { return %s }\n' "$RANDOM" "$RANDOM" >> "$1"; }
    nixbuild() { # $1=target -> "<ms> <native-rebuilds>"
      # rb counts DISTINCT native compile drvs (godyn-v2-compile-*): nix's -L
      # prints "building '<drv>'" multiple times per CA derivation, so a plain
      # grep -c overcounts (sort -u gives the true cone size). Recursive's inner
      # compiles are named godyn-compile-* and don't match -> rb is blank for it;
      # wall-clock is the metric there (its resolver re-runs nested in a wrapper).
      local bt t0 t1 rb; bt=$(mktemp -d /tmp/bd.XXXXXX); rm -f flake.lock
      t0=$(date +%s%3N); TMPDIR=$bt nix build ".#$1" -L --no-link >/dev/null 2>"$bt/e"; t1=$(date +%s%3N)
      rb=$(grep -oE 'godyn-v2-compile-[a-z0-9.-]+' "$bt/e" 2>/dev/null | sort -u | wc -l); echo "$((t1-t0)) ${rb:-0}"
    }
    gobuild() { # bga proxy: whole-subtree compile from a cold GOCACHE -> "<ms>"
      local t0 t1; t0=$(date +%s%3N)
      ( cd "$D" && GOWORK=off GOFLAGS=-mod=mod GOPROXY=off CGO_ENABLED=1 CC=$(command -v cc) \
        PATH="$goStore/bin:$PATH" GOCACHE=$(mktemp -d) go build ./internal/delta/... >/dev/null 2>&1 )
      t1=$(date +%s%3N); echo $((t1-t0))
    }
    printf '%-20s %-12s %8s %7s\n' scenario approach ms nat-rb
    revert
    for a in dewey-delta-native dewey-delta; do read -r ms rb < <(nixbuild "$a"); printf '%-20s %-12s %8s %7s\n' warm "$a" "$ms" "$rb"; done
    for ed in leaf:$LEAF foundational:$FOUND; do
      name=${ed%%:*}; file=${ed#*:}
      for a in dewey-delta-native dewey-delta; do revert; probe "$file"; read -r ms rb < <(nixbuild "$a"); printf '%-20s %-12s %8s %7s\n' "edit-$name" "$a" "$ms" "$rb"; done
      revert; probe "$file"; printf '%-20s %-12s %8s %7s\n' "edit-$name" bga-proxy "$(gobuild)" -
    done
    revert; echo "(reverted clean)"
